DATABASE_URL="postgresql://usuario:senha@localhost:5432/nomedobanco"

# Chave simétrica para assinatura de tokens (Mínimo de 32 chars recomendado em PRD)
JWT_SECRET="NUNCA_COMMITE_A_VERDADEIRA_CHAVE"

# URL base do Frontend — usada para gerar o QR Code nos certificados
# Em desenvolvimento usa-se geralmente http://localhost:4200
FRONTEND_URL="http://localhost:4200"

# Credenciais de CDN de Imagens (Serviço Storage)
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="seu_api_key"
CLOUDINARY_API_SECRET="seu_api_secret"

# Senha padrão do usuário administrador (obrigatória para `npx prisma db seed`)
# Em produção: use um valor forte e gerencie via secrets manager (ex: AWS Secrets, Vault)
# Em desenvolvimento: qualquer valor seguro serve (mínimo 8 chars, letra maiúscula + número + símbolo)
SENHA_PADRAO_ADMIN="AltereMeAgora123!"
