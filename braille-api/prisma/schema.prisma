// -------------------------------------
// CONFIGURAÇÕES DO PRISMA
// -------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------
// MODELOS DO BANCO DE DADOS
// -------------------------------------

// 1. Controle de Acesso e Perfis
enum Role {
  ADMIN
  SECRETARIA
  COMUNICACAO
  PROFESSOR
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String   
  role      Role     @default(SECRETARIA)
  fotoPerfil  String?
  turmas    Turma[]  // Relação com Turmas
  
  noticias  Noticia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Cadastro de Alunos/Assistidos
model Aluno {
  id                  String   @id @default(uuid())
  nomeCompleto        String
  cpf                 String   @unique
  dataNascimento      DateTime
  telefone            String?
  contatoEmergencia   String
  fotoPerfil          String? 
  laudoMedico         String? 
   turmas             Turma[]  // Relação com Turmas 
  
  tipoDeficiencia     String   
  leBraille           Boolean  @default(false)
  usaCaoGuia          Boolean  @default(false)
  observacoesMedicas  String?  @db.Text

  cep                 String?
  logradouro          String?
  bairro              String?
  cidade              String?
  estado              String?

  statusAtivo         Boolean  @default(true) 

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

}

// 3. Área Pública: Site Institucional (Notícias)
model Noticia {
  id              String   @id @default(uuid())
  titulo          String
  slug            String   @unique 
  conteudo        String   @db.Text
  
  imagemUrl       String?
  imagemAltText   String?  

  publicado       Boolean  @default(false)
  
  autorId         String
  autor           User     @relation(fields: [autorId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 4. Área Pública: Agenda / Eventos
model Evento {
  id              String   @id @default(uuid())
  titulo          String
  descricao       String   @db.Text
  dataEvento      DateTime
  local           String
  
  imagemUrl       String?
  imagemAltText   String?

  linkInscricao   String?  
  publicado       Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Comunicado {
  id        String   @id @default(uuid())
  titulo    String
  conteudo  String
  fixado    Boolean  @default(false) // Para prender a notícia no topo
  criadoEm  DateTime @default(now())
}

model Turma {
  id          String   @id @default(uuid())
  nome        String   // Ex: Braille Básico Nível 1
  horario     String   // Ex: Segundas e Quartas, 14h às 16h
  
  // Relação com o Professor (User)
  professorId String
  professor   User     @relation(fields: [professorId], references: [id])
  
  // Relação com os Alunos (Muitos para Muitos)
  alunos      Aluno[]
  
  statusAtivo Boolean  @default(true)
  criadoEm    DateTime @default(now())
}