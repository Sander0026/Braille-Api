generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= ENUMS (Listas Padronizadas) =================
enum Role {
  ADMIN
  SECRETARIA
  PROFESSOR
  COMUNICACAO
}

enum MatriculaStatus {
  ATIVA
  CONCLUIDA
  EVADIDA
  CANCELADA
}

enum DiaSemana {
  SEG
  TER
  QUA
  QUI
  SEX
  SAB
  DOM
}

enum TurmaStatus {
  PREVISTA    // Turma criada, ainda não iniciou
  ANDAMENTO   // Turma em andamento (default ao criar)
  CONCLUIDA   // Turma encerrada com sucesso
  CANCELADA   // Turma cancelada
}



enum TipoDeficiencia {
  CEGUEIRA_TOTAL
  BAIXA_VISAO
  VISAO_MONOCULAR
}

enum CausaDeficiencia {
  CONGENITA
  ADQUIRIDA
}

enum PreferenciaAcessibilidade {
  BRAILLE
  FONTE_AMPLIADA
  ARQUIVO_DIGITAL
  AUDIO
}

enum CategoriaComunicado {
  NOTICIA
  SERVICO
  VAGA_EMPREGO
  EVENTO_CULTURAL
  LEGISLACAO
  TRABALHO_PCD
  GERAL
}

// ================= MODELOS (Tabelas) =================

model User {
  id                 String             @id @default(uuid())
  matricula          String?            @unique              // Ex: P20260001
  nome               String
  username           String             @unique
  email              String?            @unique
  cpf                String?            @unique              // CPF do funcionário (unicidade)
  senha              String
  precisaTrocarSenha Boolean            @default(false)
  role               Role               @default(PROFESSOR)
  fotoPerfil         String?

  // Contato e Endereço (opcionais)
  telefone           String?
  cep                String?
  rua                String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  uf                 String?

  statusAtivo        Boolean            @default(true)
  excluido           Boolean            @default(false)
  criadoEm          DateTime           @default(now())
  atualizadoEm      DateTime           @updatedAt
  turmas             Turma[]
  comunicados        Comunicado[]

  @@index([statusAtivo, excluido])
  @@index([role])
  @@index([cpf])
}

model Aluno {
  id                String   @id @default(uuid())
  
  // 0. Identificação Institucional
  matricula         String?  @unique                         // Ex: 20260001 (gerado automaticamente)

  // 1. Dados Identificadores
  nomeCompleto      String
  dataNascimento    DateTime
  fotoPerfil        String?
  cpfRg             String   @unique
  genero            String?
  estadoCivil       String?

  // 2. Contato e Localização
  cep               String?
  rua               String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  uf                String?
  pontoReferencia   String?
  telefoneContato   String?
  email             String?
  contatoEmergencia String?

  // 3. Perfil da Deficiência
  tipoDeficiencia   TipoDeficiencia?
  causaDeficiencia  CausaDeficiencia?
  idadeOcorrencia   String?
  possuiLaudo       Boolean  @default(false)
  laudoUrl          String?  // URL da imagem do laudo no Cloudinary
  tecAssistivas     String?  // Ex: Bengala, cão-guia, NVDA

  // 4. Situação Socioeconômica
  escolaridade      String?
  profissao         String?
  rendaFamiliar     String?
  beneficiosGov     String?  // Ex: BPC/LOAS
  composicaoFamiliar String?

  // 5. Saúde e Autonomia
  precisaAcompanhante Boolean @default(false)
  acompOftalmologico  Boolean @default(false)
  outrasComorbidades  String?

  // 6. Preferências de Acessibilidade
  prefAcessibilidade  PreferenciaAcessibilidade?

  // Controles do Sistema
  statusAtivo       Boolean  @default(true)
  excluido          Boolean  @default(false)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  // Relacionamentos
  matriculasOficina MatriculaOficina[]
  frequencias       Frequencia[]

  @@index([statusAtivo, excluido])   // listagem de alunos ativos/inativos
  @@index([nomeCompleto])            // busca full-text por nome
  @@index([matricula])               // busca por número de matrícula
}

model Turma { // "Turma" serve perfeitamente para "Oficina"
  id               String   @id @default(uuid())
  nome             String   // Ex: Oficina de Braille, Oficina de Cerâmica
  descricao        String?
  horario          String?  // Ex: "Seg e Qua - 14h as 16h" (campo legado — Fase 3 refatorará)
  capacidadeMaxima Int?
  statusAtivo      Boolean      @default(true)
  excluido         Boolean      @default(false)
  status           TurmaStatus  @default(ANDAMENTO) // Status acadêmico da turma
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt


  // Relacionamentos
  professorId       String
  professor         User               @relation(fields: [professorId], references: [id])
  matriculasOficina MatriculaOficina[]
  frequencias       Frequencia[]
  gradeHoraria      GradeHoraria[]     // Turnos estruturados da turma

  @@index([statusAtivo, excluido])
  @@index([professorId])
}


// ── Histórico de Matrículas (Vínculo Aluno <> Turma) ──────────────
model MatriculaOficina {
  id          String          @id @default(uuid())
  status      MatriculaStatus @default(ATIVA)
  dataEntrada DateTime        @default(now())
  dataEncerramento DateTime?  // Preenchida ao Concluir/Evadir/Cancelar
  observacao  String?         // Motivo do cancelamento/evasão etc.
  criadoEm    DateTime        @default(now())
  atualizadoEm DateTime       @updatedAt

  // Relacionamentos
  alunoId     String
  aluno       Aluno  @relation(fields: [alunoId], references: [id])
  turmaId     String
  turma       Turma  @relation(fields: [turmaId], references: [id])

  @@unique([alunoId, turmaId])
  @@index([alunoId])
  @@index([turmaId, status])
}

// ── Grade Horária estruturada (Fase 3) ──────────────────────────
// horaInicio e horaFim em MINUTOS desde meia-noite (ex: 840 = 14:00, 960 = 16:00)
// Isso evita qualquer problema de timezone e torna a comparação de sobreposição trivial.
model GradeHoraria {
  id          String     @id @default(uuid())
  dia         DiaSemana
  horaInicio  Int        // Ex: 840 = 14h00
  horaFim     Int        // Ex: 960 = 16h00
  criadoEm    DateTime   @default(now())

  turmaId     String
  turma       Turma      @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([turmaId, dia])          // Uma turma só pode ter 1 horário por dia
  @@index([turmaId])
}




// Tabela de Frequência (Chamada)
model Frequencia {
  id          String   @id @default(uuid())
  dataAula    DateTime @default(now())
  presente    Boolean  @default(false)
  observacao  String?
  fechado     Boolean  @default(false) // true = diário encerrado, só ADMIN pode reabrir
  fechadoEm   DateTime?                // quando foi encerrado
  fechadoPor  String?                  // userId de quem fechou


  // Relacionamentos
  alunoId     String
  aluno       Aluno    @relation(fields: [alunoId], references: [id])
  turmaId     String
  turma       Turma    @relation(fields: [turmaId], references: [id])

  @@unique([dataAula, alunoId, turmaId]) // Evita dar falta e presença pro mesmo aluno no mesmo dia
  @@index([alunoId])                     // consultas de frequencia por aluno
  @@index([turmaId, dataAula])           // consultas de chamada por turma e data
}

model Comunicado {
  id           String   @id @default(uuid())
  titulo       String
  conteudo     String
  categoria    CategoriaComunicado @default(GERAL) 
  imagemCapa   String?
  fixado       Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  autorId      String
  autor        User     @relation(fields: [autorId], references: [id])

  @@index([categoria])                   // filtro por categoria
  @@index([fixado, criadoEm])            // listagem com fixados primeiro
  @@index([autorId])                     // comunicados por autor
}


// Tabela para o "Fale Conosco" do Site Público
model MensagemContato {
  id          String   @id @default(uuid())
  nome        String
  email       String?
  telefone    String?
  assunto     String
  mensagem    String
  lida        Boolean  @default(false)
  criadoEm    DateTime @default(now())
}

// ══════════════════ CMS — Configurações do Site ══════════════════

// Configurações gerais: cor primária, logo, nome, slogan, stats
model SiteConfig {
  chave      String   @id              // "corPrimaria" | "logo" | "nomeInstituto" …
  valor      String
  tipo       String   @default("texto") // "texto" | "cor" | "url" | "numero"
  descricao  String?
  atualizadoEm DateTime @updatedAt
}

// Conteúdo editável das seções da home pública
model ConteudoSecao {
  secao    String  // "hero" | "missao" | "valores" | "oficinas" | "depoimentos" | "cta"
  chave    String  // "titulo" | "descricao" | "card_0_titulo" …
  valor    String  @db.Text

  @@id([secao, chave])
}

// ─── FASE 5: Auditoria Central ─────────────────────────────────────────────

enum AuditAcao {
  CRIAR
  ATUALIZAR
  EXCLUIR
  ARQUIVAR
  RESTAURAR
  LOGIN
  LOGOUT
  MATRICULAR
  DESMATRICULAR
  FECHAR_DIARIO
  REABRIR_DIARIO
  MUDAR_STATUS
}

/// Registro imutável de toda ação crítica no sistema.
/// Nunca deve ser alterado ou deletado — apenas inserido.
model AuditLog {
  id         String     @id @default(cuid())
  entidade   String     // "Aluno" | "User" | "Turma" | "Frequencia" | "Auth" …
  registroId String?    // ID do registro afetado (null para LOGIN/LOGOUT)
  acao       AuditAcao
  autorId    String?    // ID do usuário que realizou a ação (null = sistema)
  autorNome  String?    // Snapshot do nome — preserva histórico mesmo se usuário for excluído
  autorRole  String?    // Snapshot do cargo (ADMIN | SECRETARIA | PROFESSOR …)
  ip         String?    // IP da requisição
  userAgent  String?    // Browser/client da requisição
  oldValue   Json?      // Estado anterior do registro (para ATUALIZAR/EXCLUIR)
  newValue   Json?      // Estado novo do registro (para CRIAR/ATUALIZAR)
  criadoEm   DateTime   @default(now())

  @@index([entidade, registroId])
  @@index([autorId])
  @@index([criadoEm])
  @@index([acao])
}
